APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:1vaU3dfc+sWjx8TuDXzginRsEa2dp2SBL+Ujs6QCb5c=
APP_DEBUG=true
APP_MODE=live
# Include the port you use locally (e.g. :8000) so central links match `php artisan serve`.
APP_URL=http://localhost:8000
# Leave empty for tenant subdomains. If set, Laravel normally serves asset() from this host only;
# tenancy clears it per-request so CSS/JS match the current host (e.g. rahul.localhost:8000).
# ASSET_URL=

LOG_CHANNEL=stack

# Central platform DB (tenants, domains, super_admins). Tenant DBs use the same MySQL user.
DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=6valy_db
CENTRAL_DB_DATABASE=6valy_db
TENANT_TEMPLATE_DB_DATABASE=6valy_db

# Comma-separated hosts for Super Admin (no tenant subdomain). Match APP_URL host.
TENANCY_CENTRAL_DOMAINS=127.0.0.1,localhost

# Subdomain suffix for new entities, e.g. acme + localhost → acme.localhost (add hosts file entries for local dev).
TENANCY_BASE_DOMAIN=localhost
#
# Tenant admin: open the full host in the browser (same port as this app), e.g. http://acme.localhost:8000/admin/auth/login
# Use the admin email/password you set on “Create entity”. Central Super Admin stays on http://localhost:8000/...
#
# Tenant storefront customers: signup/login on the same host, e.g. http://acme.localhost:8000/signup and http://acme.localhost:8000/login
# (also /customer/auth/sign-up and /customer/auth/login). Users live in each tenant DB, so admin “customer list” is per subdomain.

TENANCY_CENTRAL_CONNECTION=central
TENANCY_TEMPLATE_CONNECTION=mysql
TENANCY_DB_PREFIX=tenant

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

NEXMO_KEY=
NEXMO_SECRET=

PURCHASE_CODE=
BUYER_USERNAME=
SOFTWARE_ID=MzE0NDg1OTc=
